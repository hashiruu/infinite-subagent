# ─────────────────────────────────────────────────────────────
# fleet.env — headless Claude Code credentials for THIS host.
#
# Copy this file to ~/.claude/fleet.env on each machine that runs
# the Claude Code subagent, then fill in real values.
#
# ⚠️  NEVER commit the real fleet.env — it is gitignored on purpose.
# ─────────────────────────────────────────────────────────────

# Point Claude Code at any Anthropic-compatible endpoint.
# Use the official API, or a third-party gateway (DeepSeek, etc.).
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=sk-your-token-here

# Model overrides (optional). Set to whatever your endpoint serves.
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-sonnet-4-6
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001

# Keep Claude Code non-interactive when spawned headlessly over SSH.
CLAUDE_CODE_SIMPLE=1
